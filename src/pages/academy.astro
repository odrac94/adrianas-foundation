---
import { Image } from 'astro:assets'
import heroImg from '../assets/academy.jpg'
import modelImg from '../assets/academy-model.jpg'
import BaseLayout from '../layouts/BaseLayout.astro'

const programDetails = [
  '6-week foundational training',
  'Certified Courses',
  'Small cohorts of 10 students per class',
  'Career-specific training pathways',
  'Mentorship included',
  'Internship opportunities',
  'Job placement support',
]

const modelSteps = [
  {
    num: '01',
    title: 'Career Clarity',
    body: 'Students identify their strengths and choose a clear career path aligned with market demand.'
  },
  {
    num: '02',
    title: 'Real-World Skills',
    body: 'Students learn professional skills like communication, emotional intelligence, and workplace readiness, along with technical training for high-demand careers.'
  },
  {
    num: '03',
    title: 'Work Experience',
    body: 'Students gain hands-on experience through internships, mentorship, and real-world exposure.'
  },
  {
    num: '04',
    title: 'Job Placement',
    body: 'We support students in securing employment and launching a sustainable career path.'
  }
]

const skillCategories = [
  { title: 'Professional Skills', icon: 'briefcase' },
  { title: 'Career Development', icon: 'trending' },
  { title: 'Personal Development', icon: 'user' },
  { title: 'Workforce Readiness', icon: 'check' }
]

const applicationSteps = [
  { label: 'File Application' },
  { label: 'In Person Panel Interview' },
  { label: 'Founder Interview' },
  { label: 'Notification of Acceptance' },
  { label: 'Enrollment' },
  { label: 'Orientation' }
]
---

<BaseLayout
  title="Academy — Adriana's Foundation"
  description="Career-focused training and support program. 6-week foundational training, certified courses, mentorship, internships, and job placement support."
>
  <section class="academy-hero" aria-labelledby="academy-heading">
    <div class="academy-container">
      <div class="academy-hero-grid">
        <div class="academy-hero-text">
          <div class="academy-label" data-animate="fade-up">Academy</div>
          <h1 id="academy-heading" class="academy-title" data-animate="fade-up">
            Career-Focused Training<br />
            and <em>Support Program</em>
          </h1>
          <p class="academy-hero-lead" data-animate="fade-up" data-delay="0.1">
            A structured path designed to move students from foundational training
            to full-time employment in six weeks.
          </p>
        </div>
        <div class="academy-hero-media" data-animate="fade-left" data-delay="0.15">
          <Image
            src={heroImg}
            alt="Students at Adriana's Foundation Academy"
            class="academy-hero-img"
            width={720}
            height={900}
            loading="eager"
            format="webp"
            quality={90}
          />
          <div class="academy-hero-accent" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Program Details -->
  <section class="academy-details" aria-labelledby="details-heading">
    <div class="academy-container">
      <h2 id="details-heading" class="academy-section-title" data-animate="fade-up">
        Program Details
      </h2>
      <ul class="academy-details-list" data-animate="stagger">
        {programDetails.map((d) => (
          <li class="academy-detail-item">
            <span class="academy-detail-check" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M3.75 9l3.75 3.75 7.5-7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            {d}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Our Model: Flow Chart -->
  <section class="academy-model" aria-labelledby="model-heading">
    <div class="academy-container">
      <div class="academy-model-header">
        <div class="academy-model-header-text">
          <div class="academy-label" data-animate="fade-up">Our Model</div>
          <h2 id="model-heading" class="academy-section-title" data-animate="fade-up">
            From Training to <em>Employment</em>
          </h2>
          <p class="academy-model-lead" data-animate="fade-up" data-delay="0.1">
            Four connected stages designed to move students from early exploration
            to stable employment.
          </p>
        </div>
        <div class="academy-model-media" data-animate="fade-left" data-delay="0.15">
          <Image
            src={modelImg}
            alt="Students training at Adriana's Foundation"
            class="academy-model-img"
            width={640}
            height={480}
            loading="lazy"
            format="webp"
            quality={85}
          />
        </div>
      </div>

      <ol class="academy-flow" role="list">
        {modelSteps.map((step, i) => (
          <li class="academy-flow-step" data-animate="fade-up" data-delay={0.1 * i}>
            <div class="academy-flow-num">{step.num}</div>
            <h3 class="academy-flow-title">{step.title}</h3>
            <p class="academy-flow-body">{step.body}</p>
            {i < modelSteps.length - 1 && (
              <div class="academy-flow-arrow" aria-hidden="true">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            )}
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="academy-skills" aria-labelledby="skills-heading">
    <div class="academy-container">
      <h2 id="skills-heading" class="academy-section-title academy-section-title--centered" data-animate="fade-up">
        Skills for Career Success<br />and <em>Long-Term Growth</em>
      </h2>

      <div class="academy-skills-grid" data-animate="stagger">
        {skillCategories.map((cat) => (
          <div class="academy-skill-card">
            <div class="academy-skill-icon" aria-hidden="true">
              {cat.icon === 'briefcase' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="7" width="18" height="13" rx="2"/><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
              )}
              {cat.icon === 'trending' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
              )}
              {cat.icon === 'user' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              )}
              {cat.icon === 'check' && (
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              )}
            </div>
            <h3 class="academy-skill-title">{cat.title}</h3>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Application Process -->
  <section class="academy-apply" aria-labelledby="apply-heading">
    <div class="academy-container">
      <h2 id="apply-heading" class="academy-section-title academy-section-title--centered" data-animate="fade-up">
        Application <em>Process</em>
      </h2>
      <p class="academy-apply-intro" data-animate="fade-up">
        Six steps from application to your first day as an AGLA student.
      </p>

      <ol class="academy-timeline" role="list">
        {applicationSteps.map((step, i) => (
          <li class="academy-timeline-step" data-animate="fade-up" data-delay={0.08 * i}>
            <div class="academy-timeline-marker">
              <span class="academy-timeline-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="academy-timeline-dot" aria-hidden="true"></span>
            </div>
            <div class="academy-timeline-content">
              <h3 class="academy-timeline-label">{step.label}</h3>
              {step.sub && <p class="academy-timeline-sub">{step.sub}</p>}
            </div>
          </li>
        ))}
      </ol>

      <div class="academy-apply-cta" data-animate="fade-up">
        <a href="/contact" class="academy-cta-btn">
          Apply Now
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <path d="M3.75 9h10.5M9.75 4.5L14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .academy-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Hero ── */
  .academy-hero {
    background: var(--color-bg-warm);
    padding: 8rem 0 5rem;
  }

  .academy-hero-grid {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 4rem;
    align-items: center;
  }

  .academy-hero-lead {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: rgba(0, 0, 0, 0.65);
    line-height: 1.7;
    margin: 1.5rem 0 0;
    max-width: 440px;
  }

  .academy-hero-media {
    position: relative;
    justify-self: end;
    width: 100%;
    max-width: 460px;
  }

  .academy-hero-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 1rem;
    position: relative;
    z-index: 2;
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.15);
  }

  .academy-hero-accent {
    position: absolute;
    inset: 0;
    border: 2px solid var(--color-gold);
    border-radius: 1rem;
    transform: translate(12px, 12px);
    z-index: 1;
    opacity: 0.5;
  }

  .academy-label {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-terracotta);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.25rem;
  }

  .academy-label--centered {
    text-align: center;
  }

  .academy-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    font-weight: 900;
    color: var(--color-bg-dark);
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .academy-title em {
    font-style: italic;
    color: var(--color-gold);
  }

  .academy-section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    color: var(--color-bg-dark);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 3rem;
  }

  .academy-section-title--centered {
    text-align: center;
  }

  .academy-section-title em {
    font-style: italic;
    color: var(--color-gold);
  }

  /* ── Program Details ── */
  .academy-details {
    background: var(--color-bg-light-gray);
    padding: 5rem 0;
  }

  .academy-details-list {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .academy-detail-item {
    grid-column: span 2 / span 2;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1.25rem 1.5rem;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 0.625rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-bg-dark);
    font-weight: 500;
  }

  /* Row 1 — 4 items aligned across 8 columns */
  .academy-detail-item:nth-child(1) { grid-column-start: 1; grid-row-start: 1; }
  .academy-detail-item:nth-child(2) { grid-column-start: 3; grid-row-start: 1; }
  .academy-detail-item:nth-child(3) { grid-column-start: 5; grid-row-start: 1; }
  .academy-detail-item:nth-child(4) { grid-column-start: 7; grid-row-start: 1; }

  /* Row 2 — 3 items centered between the 4 above */
  .academy-detail-item:nth-child(5) { grid-column-start: 2; grid-row-start: 2; }
  .academy-detail-item:nth-child(6) { grid-column-start: 4; grid-row-start: 2; }
  .academy-detail-item:nth-child(7) { grid-column-start: 6; grid-row-start: 2; }

  .academy-detail-check {
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(233, 173, 0, 0.15);
    border-radius: 50%;
    color: var(--color-gold);
    flex-shrink: 0;
  }

  /* ── Model: Flow Chart ── */
  .academy-model {
    background: var(--color-bg-warm);
    padding: 6rem 0;
  }

  .academy-model-header {
    display: grid;
    grid-template-columns: 1fr 0.8fr;
    gap: 4rem;
    align-items: center;
    margin-bottom: 4rem;
  }

  .academy-model-lead {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    color: rgba(0, 0, 0, 0.65);
    line-height: 1.7;
    margin: 1rem 0 0;
    max-width: 480px;
  }

  .academy-model-media {
    justify-self: end;
    width: 100%;
    max-width: 440px;
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.1);
  }

  .academy-model-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .academy-flow {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    align-items: stretch;
  }

  .academy-flow-step {
    position: relative;
    padding: 2rem 1.5rem;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 0.75rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .academy-flow-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--color-gold);
    line-height: 1;
    margin-bottom: 1rem;
    letter-spacing: -0.03em;
  }

  .academy-flow-title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-bg-dark);
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .academy-flow-body {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: rgba(0, 0, 0, 0.65);
    line-height: 1.6;
    margin: 0;
  }

  .academy-flow-arrow {
    position: absolute;
    right: -2rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-gold);
    z-index: 2;
    background: var(--color-bg-warm);
    padding: 0.25rem;
    border-radius: 50%;
  }

  /* ── Skills ── */
  .academy-skills {
    background: var(--color-bg-light-gray);
    padding: 6rem 0;
  }

  .academy-skills-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .academy-skill-card {
    padding: 2.5rem 1.5rem;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 0.75rem;
    text-align: center;
    transition: transform 0.2s, border-color 0.2s;
  }

  .academy-skill-card:hover {
    transform: translateY(-4px);
    border-color: rgba(233, 173, 0, 0.4);
  }

  .academy-skill-icon {
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(233, 173, 0, 0.12);
    border-radius: 50%;
    color: var(--color-gold);
    margin: 0 auto 1.25rem;
  }

  .academy-skill-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-bg-dark);
    margin: 0;
  }

  /* ── Application Process ── */
  .academy-apply {
    background: var(--color-bg-warm);
    padding: 6rem 0;
  }

  .academy-apply-intro {
    text-align: center;
    font-family: var(--font-body);
    font-size: 1.0625rem;
    color: rgba(0, 0, 0, 0.55);
    margin: -2rem auto 3.5rem;
    max-width: 560px;
  }

  /* Timeline */
  .academy-timeline {
    list-style: none;
    margin: 0 0 4rem;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0;
    position: relative;
    max-width: 1080px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Connector line behind markers */
  .academy-timeline::before {
    content: '';
    position: absolute;
    top: 1.5rem;
    left: calc((100% / 6) / 2);
    right: calc((100% / 6) / 2);
    height: 2px;
    background: linear-gradient(
      to right,
      var(--color-gold) 0%,
      var(--color-gold) 50%,
      rgba(233, 173, 0, 0.25) 100%
    );
    z-index: 0;
  }

  .academy-timeline-step {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 0.75rem;
    position: relative;
    z-index: 2;
  }

  .academy-timeline-marker {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: #fff;
    border: 2px solid var(--color-gold);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    margin-bottom: 1.25rem;
    box-shadow: 0 4px 12px rgba(233, 173, 0, 0.15);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .academy-timeline-step:hover .academy-timeline-marker {
    transform: translateY(-3px);
    box-shadow: 0 8px 20px rgba(233, 173, 0, 0.25);
  }

  .academy-timeline-num {
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 900;
    color: var(--color-bg-dark);
    letter-spacing: -0.02em;
  }

  .academy-timeline-dot {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px solid rgba(233, 173, 0, 0.3);
    opacity: 0;
    transition: opacity 0.3s, transform 0.3s;
  }

  .academy-timeline-step:hover .academy-timeline-dot {
    opacity: 1;
    transform: scale(1.1);
  }

  .academy-timeline-content {
    text-align: center;
  }

  .academy-timeline-label {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-bg-dark);
    margin: 0 0 0.25rem;
    line-height: 1.25;
  }

  .academy-timeline-sub {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: rgba(0, 0, 0, 0.5);
    margin: 0;
    line-height: 1.35;
  }

  .academy-apply-cta {
    text-align: center;
  }

  .academy-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1.125rem 2.5rem;
    background: var(--color-gold);
    color: var(--color-bg-dark);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 3rem;
    box-shadow: 0 6px 20px rgba(233, 173, 0, 0.3);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .academy-cta-btn:hover {
    background: #FFD040;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(233, 173, 0, 0.4);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .academy-hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .academy-hero-media {
      justify-self: center;
      max-width: 380px;
    }

    .academy-model-header {
      grid-template-columns: 1fr;
      gap: 2rem;
      text-align: center;
    }

    .academy-model-media {
      justify-self: center;
      max-width: 520px;
    }

    .academy-model-lead {
      margin-left: auto;
      margin-right: auto;
    }

    .academy-flow {
      grid-template-columns: 1fr;
    }

    .academy-flow-arrow {
      position: static;
      transform: rotate(90deg);
      margin: 1rem auto 0;
      display: block;
      width: fit-content;
    }

    .academy-skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* Details: relax the 8-col grid into simple 2-col on tablet */
    .academy-details-list {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }

    .academy-detail-item,
    .academy-detail-item:nth-child(1),
    .academy-detail-item:nth-child(2),
    .academy-detail-item:nth-child(3),
    .academy-detail-item:nth-child(4),
    .academy-detail-item:nth-child(5),
    .academy-detail-item:nth-child(6),
    .academy-detail-item:nth-child(7) {
      grid-column: auto;
      grid-row: auto;
    }

    /* Timeline goes vertical */
    .academy-timeline {
      grid-template-columns: 1fr;
      gap: 2rem;
      max-width: 480px;
    }

    .academy-timeline::before {
      top: 0;
      bottom: 0;
      left: 1.5rem;
      right: auto;
      width: 2px;
      height: auto;
      background: linear-gradient(
        to bottom,
        var(--color-gold) 0%,
        var(--color-gold) 50%,
