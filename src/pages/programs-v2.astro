---
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'
import { getPrograms } from '../content/programs'

const programs = getPrograms()

const categoryColors: Record<string, string> = {
  mentorship: '#E9AD00',
  sports: 'var(--color-terracotta)',
  community: '#4A9BD9',
  partnership: '#7BCFED'
}

const categoryLabels: Record<string, string> = {
  mentorship: 'Mentorship',
  sports: 'Sports',
  community: 'Community',
  partnership: 'Partnership'
}
---

<BaseLayout
  title="Programs — Adriana's Foundation"
  description="Explore all 8 programs from Adriana's Foundation — from Elevate Academy and Soccer Academy to the Annual Santa Tour and Festival de La Familia."
>
  <section class="pp" aria-labelledby="pp-heading">
    <div class="pp-container">

      <!-- Header -->
      <div class="pp-header" data-animate="fade-up">
        <div class="pp-label">Programming</div>
        <h1 id="pp-heading" class="pp-title">Our Programs</h1>
        <p class="pp-subtitle">
          From mentorship to soccer academies, every program is designed to create access,
          build confidence, and open doors for Latino youth and families.
        </p>
        <p class="pp-funding">
          Funded through private sponsorships, community partnerships, and in-kind contributions.
          <strong>100% of proceeds</strong> are reinvested into programs that directly benefit the communities we serve.
        </p>
      </div>

      <!-- Tab system -->
      <div class="pp-tabs">
        {/* Hidden radio inputs */}
        {programs.map((p, i) => (
          <input
            type="radio"
            name="program-tab"
            id={`tab-${p.id}`}
            class="pp-radio"
            checked={i === 0}
            aria-hidden="true"
          />
        ))}

        <!-- Detail panels FIRST (above grid) -->
        <div class="pp-panels">
          {programs.map((p) => {
            const accent = categoryColors[p.category] ?? '#E9AD00'
            return (
              <div
                class="pp-panel"
                id={`panel-${p.id}`}
                role="tabpanel"
                aria-labelledby={p.id}
                style={`--accent: ${accent}`}
              >
                <div class="pp-panel-inner">
              <div class="pp-panel-img-wrap">
                    {typeof p.image === 'string' ? (
                      <img src={p.image} alt={p.title} class="pp-panel-img" width="800" height="500" loading="lazy" />
                    ) : p.image ? (
                      <Image src={p.image} alt={p.title} class="pp-panel-img" width={800} height={500} loading="lazy" format="webp" quality={85} />
                    ) : null}
                  </div>
                  <div class="pp-panel-content-wrap">
                  <div class="pp-panel-content">
                    <h2 class="pp-panel-title">{p.title}</h2>
                    <p class="pp-panel-desc">{p.description}</p>
                    <div class="pp-panel-sections">
                      <div class="pp-panel-section">
                        <h3 class="pp-panel-section-title">Goals</h3>
                        <ul class="pp-panel-list" role="list">
                          {p.goals.map((g) => (
                            <li class="pp-panel-list-item">
                              <span class="pp-panel-marker" aria-hidden="true">›</span>
                              {g}
                            </li>
                          ))}
                        </ul>
                      </div>
                      <div class="pp-panel-section">
                        <h3 class="pp-panel-section-title">Key Components</h3>
                        <ul class="pp-panel-list" role="list">
                          {p.keyComponents.map((k) => (
                            <li class="pp-panel-list-item">
                              <span class="pp-panel-marker" aria-hidden="true">✦</span>
                              {k}
                            </li>
                          ))}
                        </ul>
                      </div>
                    </div>
                  </div>
                  </div>
                </div>
              </div>
            )
          })}
        </div>

        <!-- Card grid SECOND (below panel) — no images, just badge + title + tagline -->
        <div class="pp-grid" role="tablist" aria-label="Select a program">
          {programs.map((p) => {
            const accent = categoryColors[p.category] ?? '#E9AD00'
            const catLabel = categoryLabels[p.category] ?? p.category
            return (
              <label
                for={`tab-${p.id}`}
                class="pp-card"
                style={`--accent: ${accent}`}
                role="tab"
                aria-controls={`panel-${p.id}`}
                id={p.id}
              >
                <span class="pp-card-badge">{catLabel}</span>
                <h3 class="pp-card-title">{p.title}</h3>
                <p class="pp-card-tagline">{p.tagline}</p>
                <div class="pp-card-indicator" aria-hidden="true"></div>
              </label>
            )
          })}
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<script>
  function activateTabFromHash(): void {
    const hash = window.location.hash.slice(1) // remove #
    if (!hash) return

    const radio = document.getElementById(`tab-${hash}`) as HTMLInputElement | null
    if (radio) {
      radio.checked = true
      // Scroll to panels area
      const panels = document.querySelector('.pp-panels')
      if (panels) {
        panels.scrollIntoView({ behavior: 'smooth', block: 'start' })
      }
    }
  }

  // Run on load
  activateTabFromHash()

  // Handle hash changes (back/forward navigation)
  window.addEventListener('hashchange', activateTabFromHash)

  // Re-run after Astro view transitions
  document.addEventListener('astro:page-load', activateTabFromHash)
</script>

<style>
  .pp {
    background: var(--color-bg-warm);
    min-height: 100vh;
    padding: 8rem 0 6rem;
  }

  .pp-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ── */
  .pp-header { margin-bottom: 4rem; max-width: 720px; }

  .pp-label {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-terracotta);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }

  .pp-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 900;
    color: var(--color-bg-dark);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
  }

  .pp-subtitle {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: rgba(0, 0, 0, 0.6);
    line-height: 1.7;
    margin: 0 0 1rem;
  }

  .pp-funding {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(0, 0, 0, 0.45);
    line-height: 1.6;
    margin: 0;
  }

  .pp-funding strong { color: var(--color-terracotta); font-weight: 600; }

  /* ── Hidden radios ── */
  .pp-radio {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }

  /* ── Detail panels (above grid) ── */
  .pp-panels {
    margin-bottom: 1.5rem;
  }

  .pp-panel {
    display: none;
    background: var(--color-bg-light-gray);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 0.75rem;
    overflow: hidden;
    animation: panelFadeIn 0.35s ease;
  }

  @keyframes panelFadeIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .pp-panel-inner {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 0;
    min-height: 400px;
  }

  .pp-panel-img-wrap { overflow: hidden; }

  .pp-panel-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pp-panel-content-wrap {
    position: relative;
    overflow: hidden;
  }

  .pp-panel-content-wrap::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 4rem;
    background: linear-gradient(to bottom, transparent, var(--color-bg-light-gray));
    pointer-events: none;
    z-index: 1;
  }

  .pp-panel-content {
    padding: 2.5rem;
    overflow-y: auto;
    max-height: 550px;
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.2) transparent;
  }

  .pp-panel-content::-webkit-scrollbar {
    width: 4px;
  }

  .pp-panel-content::-webkit-scrollbar-track {
    background: transparent;
  }

  .pp-panel-content::-webkit-scrollbar-thumb {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 2px;
  }

  .pp-panel-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-bg-dark);
    margin: 0 0 1rem;
    line-height: 1.2;
  }

  .pp-panel-desc {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: rgba(0, 0, 0, 0.7);
    line-height: 1.75;
    margin: 0 0 2rem;
  }

  .pp-panel-sections {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .pp-panel-section-title {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .pp-panel-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pp-panel-list-item {
    display: flex;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: rgba(0, 0, 0, 0.65);
    line-height: 1.55;
  }

  .pp-panel-marker {
    color: var(--accent);
    flex-shrink: 0;
    font-weight: 700;
    font-size: 0.75rem;
    margin-top: 0.1rem;
  }

  /* ── Card grid (below panel) — text only ── */
  .pp-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.875rem;
  }

  .pp-card {
    position: relative;
    /* background: rgba(255, 255, 255, 0.7); */
    background: var(--color-bg-light-gray);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 0.625rem;
    padding: 1.25rem;
    cursor: pointer;
    transition: border-color 0.25s, transform 0.2s, background 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    overflow: hidden;
  }

  .pp-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.9);
  }

  .pp-card-badge {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-body);
    font-size: 0.5625rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--accent);
    border-radius: 2rem;
    opacity: 0.8;
  }

  .pp-card-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-bg-dark);
    margin: 0;
    line-height: 1.25;
  }

  .pp-card-tagline {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(0, 0, 0, 0.5);
    line-height: 1.45;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Active indicator — top bar */
  .pp-card-indicator {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent);
    border-radius: 0.625rem 0.625rem 0 0;
    transform: scaleX(0);
    transition: transform 0.25s ease;
  }

  /* ══════════════════════════════════════
     CSS :has() tab switching
     ══════════════════════════════════════ */

  /* Active card highlight */
  .pp-tabs:has(#tab-agla-academy:checked) .pp-grid label[for="tab-agla-academy"],
  .pp-tabs:has(#tab-adrianas-soccer-academy:checked) .pp-grid label[for="tab-adrianas-soccer-academy"],
  .pp-tabs:has(#tab-annual-copa-adrianas-soccer-tournament:checked) .pp-grid label[for="tab-annual-copa-adrianas-soccer-tournament"],
  .pp-tabs:has(#tab-annual-back-to-school-drive:checked) .pp-grid label[for="tab-annual-back-to-school-drive"],
  .pp-tabs:has(#tab-annual-santa-tour:checked) .pp-grid label[for="tab-annual-santa-tour"],
  .pp-tabs:has(#tab-festival-de-la-familia:checked) .pp-grid label[for="tab-festival-de-la-familia"],
  .pp-tabs:has(#tab-annual-food-drive:checked) .pp-grid label[for="tab-annual-food-drive"],
  .pp-tabs:has(#tab-global-community-partnerships:checked) .pp-grid label[for="tab-global-community-partnerships"] {
    border-color: var(--accent);
    background: var(--color-bg-light-gray);
  }

  /* Active indicator bar */
  .pp-tabs:has(#tab-agla-academy:checked) label[for="tab-agla-academy"] .pp-card-indicator,
  .pp-tabs:has(#tab-adrianas-soccer-academy:checked) label[for="tab-adrianas-soccer-academy"] .pp-card-indicator,
  .pp-tabs:has(#tab-annual-copa-adrianas-soccer-tournament:checked) label[for="tab-annual-copa-adrianas-soccer-tournament"] .pp-card-indicator,
  .pp-tabs:has(#tab-annual-back-to-school-drive:checked) label[for="tab-annual-back-to-school-drive"] .pp-card-indicator,
  .pp-tabs:has(#tab-annual-santa-tour:checked) label[for="tab-annual-santa-tour"] .pp-card-indicator,
  .pp-tabs:has(#tab-festival-de-la-familia:checked) label[for="tab-festival-de-la-familia"] .pp-card-indicator,
  .pp-tabs:has(#tab-annual-food-drive:checked) label[for="tab-annual-food-drive"] .pp-card-indicator,
  .pp-tabs:has(#tab-global-community-partnerships:checked) label[for="tab-global-community-partnerships"] .pp-card-indicator {
    transform: scaleX(1);
  }

  /* Show panel */
  .pp-tabs:has(#tab-agla-academy:checked) #panel-agla-academy,
  .pp-tabs:has(#tab-adrianas-soccer-academy:checked) #panel-adrianas-soccer-academy,
  .pp-tabs:has(#tab-annual-copa-adrianas-soccer-tournament:checked) #panel-annual-copa-adrianas-soccer-tournament,
  .pp-tabs:has(#tab-annual-back-to-school-drive:checked) #panel-annual-back-to-school-drive,
  .pp-tabs:has(#tab-annual-santa-tour:checked) #panel-annual-santa-tour,
  .pp-tabs:has(#tab-festival-de-la-familia:checked) #panel-festival-de-la-familia,
  .pp-tabs:has(#tab-annual-food-drive:checked) #panel-annual-food-drive,
  .pp-tabs:has(#tab-global-community-partnerships:checked) #panel-global-community-partnerships {
    display: block;
  }

  /* ── Responsive ── */
  @media (max-width: 1200px) {
    .pp-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 900px) {
    .pp-grid { grid-template-columns: repeat(2, 1fr); }
    .pp-panel-inner { grid-template-columns: 1fr; }
    .pp-panel-img-wrap { max-height: none; }
    .pp-panel-img { aspect-ratio: 16 / 9; object-fit: cover; }
  }

  @media (max-width: 640px) {
    /* Reorder: grid on top, panels below */
    .pp-tabs {
      display: flex;
      flex-direction: column;
    }

    .pp-grid {
      order: -1; /* move above panels */
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      gap: 0.5rem;
      padding-bottom: 0.75rem;
      margin-bottom: 1rem;
      scrollbar-width: none; /* Firefox */
    }

    .pp-grid::-webkit-scrollbar { display: none; }

    .pp-card {
      flex: 0 0 auto;
      width: 140px;
      scroll-snap-align: start;
      padding: 0.75rem;
      gap: 0.25rem;
      border-radius: 0.5rem;
    }

    /* Hide badge and tagline on mobile slider — title only */
    .pp-card-badge {
      font-size: 0.5rem;
      padding: 0.15rem 0.375rem;
    }

    .pp-card-tagline { display: none; }

    .pp-card-title {
      font-size: 0.8125rem;
      line-height: 1.2;
    }

    /* Indicator on bottom for mobile (points down to panel) */
    .pp-card-indicator {
      top: auto;
      bottom: 0;
      border-radius: 0 0 0.5rem 0.5rem;
    }

    .pp-panels {
      order: 1;
      margin-bottom: 0;
    }

    .pp-panel-inner { grid-template-columns: 1fr; }
    .pp-panel-img-wrap { max-height: none; }
    .pp-panel-img { object-position: center; aspect-ratio: 16 / 9; object-fit: cover; }
    .pp-panel-content { padding: 1.25rem; max-height: 400px; }
    .pp-panel-title { font-size: 1.375rem; }
    .pp-panel-desc { font-size: 0.9375rem; margin-bottom: 1.5rem; }
  }
</style>
