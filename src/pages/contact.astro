---
import BaseLayout from '../layouts/BaseLayout.astro'
import ContactCategory from '../components/contact/ContactCategory.astro'
import type { ContactEntry } from '../types/index'

const contactEntries: ContactEntry[] = [
  {
    category: 'General Inquiries',
    description: 'For general questions or more information about Adriana\'s Foundation.',
    email: 'info@adrianasfoundation.org'
  },
  {
    category: 'Partnerships',
    description: 'Looking to collaborate or explore partnership opportunities?',
    email: 'partnerships@adrianasfoundation.org'
  },
  {
    category: 'Donations & Giving',
    description: 'Interested in supporting our mission or making a contribution? Reach out to our giving team.',
    email: 'giving@adrianasfoundation.org'
  },
  {
    category: 'Press & Media',
    description: 'For media inquiries, interviews, or press opportunities.',
    email: 'press@adrianasfoundation.org'
  },
  {
    category: 'Programs',
    description: 'Have questions about our programs or how to participate?',
    email: 'programs@adrianasfoundation.org'
  }
]

const categoryIcons: Record<string, string> = {
  'General Inquiries': '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M8 8a3.5 3 0 0 1 3.5 -3h1a3.5 3 0 0 1 3.5 3a3 3 0 0 1 -2 3a3 4 0 0 0 -2 4" /><path d="M12 19l0 .01" /></svg>',
  'Donations & Giving': '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M14.872 11.13a3.001 3.001 0 1 0 -4.29 3.514" /><path d="M10 18h-5a2 2 0 0 1 -2 -2v-8a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v3" /><path d="M6 12h.01" /><path d="M18 22l3.35 -3.284a2.143 2.143 0 0 0 .005 -3.071a2.24 2.24 0 0 0 -3.129 -.006l-.224 .22l-.223 -.22a2.24 2.24 0 0 0 -3.128 -.006a2.143 2.143 0 0 0 -.006 3.071l3.355 3.296" /></svg>',
  'Programs': '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M11 4a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M3 17l5 1l.75 -1.5" /><path d="M14 21v-4l-4 -3l1 -6" /><path d="M6 12v-3l5 -1l3 3l3 1" /><path d="M19.5 20a.5 .5 0 1 0 0 -1a.5 .5 0 0 0 0 1" fill="currentColor" /></svg>',
  'Partnerships': '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M8 21h-2a3 3 0 0 1 -3 -3v-1h5.5" /><path d="M17 8.5v-3.5a2 2 0 1 1 2 2h-2" /><path d="M19 3h-11a3 3 0 0 0 -3 3v11" /><path d="M9 7h4" /><path d="M9 11h4" /><path d="M18.42 12.61a2.1 2.1 0 0 1 2.97 2.97l-6.39 6.42h-3v-3l6.42 -6.39" /></svg>',
  'Press & Media': '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M3 9a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v9a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2l0 -9" /><path d="M16 3l-4 4l-4 -4" /><path d="M15 7v13" /><path d="M18 15v.01" /><path d="M18 12v.01" /></svg>'
}
---

<BaseLayout
  title="Contact Us — Adriana's Foundation"
  description="Get in touch with Adriana's Foundation. Reach out for general inquiries, partnerships, donations, press, or program questions."
>
  <section class="contact-page" aria-labelledby="contact-heading">
    <div class="contact-page-container">

      <!-- Header -->
      <div class="contact-page-header">
        <div class="contact-page-label" aria-hidden="true">Get In Touch</div>
        <h1 id="contact-heading" class="contact-page-heading">
          We'd love to<br />
          hear from you
        </h1>
        <p class="contact-page-subheading">
          Reach out with any questions, opportunities to get involved,
          or ways to support our mission.
        </p>
      </div>

      <!-- Contact categories grid -->
      <div class="contact-grid" aria-label="Contact categories">
        {contactEntries.map((entry) => (
          <ContactCategory
            entry={entry}
            iconHtml={categoryIcons[entry.category] ?? ''}
          />
        ))}
      </div>

      <!-- Get Involved Form -->
      <div class="contact-form-section" data-animate="fade-up">
        <div class="contact-form-header">
          <div class="contact-form-label" aria-hidden="true">Get Involved</div>
          <h2 class="contact-form-heading">Join our community</h2>
          <p class="contact-form-subtext">
            Leave your information and we'll reach out about volunteer opportunities,
            events, and ways to make an impact.
          </p>
        </div>

        <div class="contact-form-embed">
          <iframe
            id="JotFormIFrame-261187937401864"
            title="Get Involved Form"
            src="https://form.jotform.com/261187937401864?isIframeEmbed=1&background=FFFFFF"
            style="min-width:100%;max-width:100%;border:none;"
            scrolling="no"
            allow="geolocation; microphone; camera; fullscreen"
          ></iframe>
        </div>
        <script is:inline>
          // Auto-resize JotForm iframe
          window.addEventListener('message', function(e) {
            if (typeof e.data === 'object') return;
            var args = e.data.split(':');
            if (args.length > 2) { 
              var iframe = document.getElementById('JotFormIFrame-' + args[args.length - 1]);
              if (!iframe) return;
              switch (args[0]) {
                case 'setHeight':
                  iframe.style.height = args[1] + 'px';
                  break;
                case 'scrollIntoView':
                  iframe.scrollIntoView();
                  break;
              }
            }
          });
        </script>
      </div>

      <!-- Give Today CTA -->
      <div class="contact-donate">
        <div class="contact-donate-content">
          <h2 class="contact-donate-heading">Ready to build a better future?</h2>
          <p class="contact-donate-text">
            Whether you are a student, donor, employer, or community partner,
            you can be part of the pathway from training to employment.
          </p>
        </div>
        <div class="contact-donate-actions">
          <a
            href="/academy"
            class="contact-donate-btn"
          >
            Apply for the Program
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a
            href="/donate"
            class="contact-donate-btn-secondary"
          >
            Support Adriana's Foundation
          </a>
        </div>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    background: var(--color-bg-warm);
    min-height: 100vh;
    padding: 8rem 0 6rem;
  }

  .contact-page-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .contact-page-header {
    margin-bottom: 4rem;
    max-width: 600px;
  }

  .contact-page-label {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-terracotta);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }

  .contact-page-heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 900;
    color: var(--color-bg-dark);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
  }

  .contact-page-subheading {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: rgba(0, 0, 0, 0.6);
    line-height: 1.7;
    margin: 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 4rem;
  }

  /* Last item (Programs) spans full width if odd count */
  .contact-grid > :last-child:nth-child(odd) {
    grid-column: span 2;
  }

  /* Donate CTA */
  .contact-donate {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding: 2.5rem 3rem;
    background: rgba(6, 87, 154, 0.08);
    border: 1px solid rgba(6, 87, 154, 0.15);
    border-radius: 0.75rem;
    flex-wrap: wrap;
  }

  .contact-donate-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-bg-dark);
    margin: 0 0 0.5rem;
  }

  .contact-donate-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: rgba(0, 0, 0, 0.6);
    margin: 0;
  }

  .contact-donate-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    background: var(--color-gold);
    color: var(--color-bg-dark);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 3rem;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s;
  }

  .contact-donate-btn:hover {
    background: #FFD040;
    transform: translateY(-1px);
  }

  .contact-donate-btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 2rem;
    background: transparent;
    color: var(--color-bg-dark);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid var(--color-bg-dark);
    border-radius: 3rem;
    white-space: nowrap;
    transition: background 0.2s, color 0.2s, transform 0.15s;
  }

  .contact-donate-btn-secondary:hover {
    background: var(--color-bg-dark);
    color: var(--color-gold);
    transform: translateY(-1px);
  }

  .contact-donate-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; margin-bottom: 20px;}
    .contact-grid > :last-child:nth-child(odd) { grid-column: span 1; }
    .contact-donate { flex-direction: column; align-items: flex-start; }
  }

  /* Get Involved Form */
  .contact-form-section {
    margin-bottom: 4rem;
    padding: 3rem;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 0.75rem;
  }

  @media (max-width: 768px) {
    .contact-form-section {
      padding: 1.25rem;
      margin-bottom: 20px;
    }
  }

  .contact-form-header {
    margin-bottom: 2rem;
  }

  .contact-form-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-terracotta);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.75rem;
  }

  .contact-form-heading {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: var(--color-bg-dark);
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .contact-form-subtext {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(0, 0, 0, 0.55);
    line-height: 1.6;
    margin: 0;
    max-width: 520px;
  }

  .contact-form-embed {
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .contact-form-embed iframe {
    display: block;
  }
</style>
