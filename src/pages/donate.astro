---
import { Image } from 'astro:assets'
import BaseLayout from '../layouts/BaseLayout.astro'
import donatePhoto from '../assets/donate-section.jpg'
import donate1 from '../assets/donate/donate-1.jpg'
import donate2 from '../assets/donate/donate-2.jpg'
import donate3 from '../assets/donate/donate-3.jpg'
import donate4 from '../assets/donate/donate-4.jpg'
import donate5 from '../assets/donate/donate-5.jpg'
import donate6 from '../assets/donate/donate-6.jpg'
import donate7 from '../assets/donate/donate-7.jpg'
import donate8 from '../assets/donate/donate-8.jpg'

const carouselImages = [donate1, donate2, donate3, donate4, donate5, donate6, donate7, donate8]

const amounts = [
  { value: 50,   url: 'https://buy.stripe.com/00g2bg9o7dGma6k289' },
  { value: 100,  url: 'https://buy.stripe.com/eVa5nsasbfOuemA002' },
  { value: 500,  url: 'https://buy.stripe.com/8wMcPUbwf7hYguIfZ1' },
  { value: 1000, url: 'https://buy.stripe.com/bIYg260RB31I5Q46os' },
  { value: 2500, url: 'https://buy.stripe.com/28o038eIrfOu0vK7sx' },
  { value: 5000, url: 'https://buy.stripe.com/14kcPU9o76dU1zO6ou' },
]

const impactMap: Record<number, string> = {
  50:   'Covers student supplies for one AGLA participant.',
  100:  'Funds a mentorship session for a student in the Academy.',
  500:  'Supports AGLA training materials for one student.',
  1000: 'Sponsors one student through the 6-week foundational program.',
  2500: 'Funds a full training pathway including certifications.',
  5000: 'Sponsors an entire cohort of 10 AGLA students.',
}

const customUrl = 'https://buy.stripe.com/14kdTYeIrfOudiwdQX'
---

<BaseLayout
  title="For Donors & Partners — Adriana's Foundation"
  description="Join us in turning education into employment. Your support provides free training, mentorship, internships, and job placement services."
>
  <div class="donate-page">
    <!-- Grain texture -->
    <div class="donate-grain" style="background-image: url('/textures/grain.svg')" aria-hidden="true"></div>

    <!-- Mesh background -->
    <div class="donate-mesh" aria-hidden="true"></div>

    <div class="donate-inner">

      <!-- ── Left: copy + image ── -->
      <div class="donate-left">
        <div class="donate-eyebrow">
          <span class="donate-eyebrow-line" aria-hidden="true"></span>
          For Donors &amp; Partners
        </div>

        <h1 class="donate-heading">
          Join us in turning<br />
          <em>education into employment</em>
        </h1>

        <p class="donate-lead">
          Your support helps provide free training, mentorship, internships, and
          job placement services for students ready to transform their future.
        </p>

        <!-- Ways to Support -->
        <div class="donate-ways-support" aria-label="Ways to support">
          <div class="donate-ways-support-title">Ways to Support</div>
          <ul class="donate-ways-support-list" role="list">
            <li>Cover Student Supplies</li>
            <li>Sponsor a Student</li>
            <li>Fund a Cohort</li>
            <li>Become an Employer Partner</li>
            <li>Provide Mentorship</li>
            <li>Support Program Operations</li>
          </ul>
        </div>

        <!-- Partner CTAs -->
        <div class="donate-partner-ctas">
          <a
            href="/contact"
            class="donate-partner-btn"
          >
            Partner With Us
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a href="#donate-amounts" class="donate-partner-btn-secondary">
            Donate Now
          </a>
        </div>

        <!-- Impact carousel -->
        <div class="donate-carousel" aria-label="Community impact photos">
          <div class="donate-carousel-track">
            {carouselImages.map((img, i) => (
              <div class="donate-carousel-slide">
                <Image
                  src={img}
                  alt={`Community impact ${i + 1}`}
                  class="donate-carousel-img"
                  loading={i < 2 ? 'eager' : 'lazy'}
                />
              </div>
            ))}
            {/* Duplicate for seamless loop */}
            {carouselImages.map((img, i) => (
              <div class="donate-carousel-slide" aria-hidden="true">
                <Image
                  src={img}
                  alt=""
                  class="donate-carousel-img"
                  loading="lazy"
                />
              </div>
            ))}
          </div>
        </div>

        <!-- Impact quote -->
        <blockquote class="donate-quote">
          <p>"When one person rises, the community rises with them."</p>
          <footer><cite>— Adriana Gallardo, Founder</cite></footer>
        </blockquote>
      </div>

      <!-- ── Right: donation selector ── -->
      <div class="donate-right" id="donate-amounts">
        <div class="donate-card">
          <div class="donate-card-header">
            <h2 class="donate-card-title">Choose a donation amount</h2>
            <p class="donate-card-sub">Select an amount or enter a custom gift</p>
          </div>

          <!-- Amount grid -->
          <div class="donate-amounts" role="list" aria-label="Donation amount options">
            {amounts.map((amount) => (
              <a
                href={amount.url}
                target="_blank"
                rel="noopener noreferrer"
                class="donate-amount-btn"
                role="listitem"
                aria-label={`Donate $${amount.value.toLocaleString()} — ${impactMap[amount.value]}`}
              >
                <span class="donate-amount-value">${amount.value.toLocaleString()}</span>
                <span class="donate-amount-impact">{impactMap[amount.value]}</span>
              </a>
            ))}
          </div>

          <!-- Custom amount -->
          <div class="donate-custom">
            <div class="donate-custom-label">Custom amount</div>
            <a
              href="https://buy.stripe.com/14kdTYeIrfOudiwdQX"
              target="_blank"
              rel="noopener noreferrer"
              class="donate-custom-btn"
            >
              Enter a custom amount
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          <!-- Trust signals -->
          <div class="donate-trust" aria-label="Trust indicators">
            <div class="donate-trust-item">
              <span class="donate-trust-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M8.487 21h7.026a4 4 0 0 0 3.808 -5.224l-1.706 -5.306a5 5 0 0 0 -4.76 -3.47h-1.71a5 5 0 0 0 -4.76 3.47l-1.706 5.306a4 4 0 0 0 3.808 5.224" /><path d="M15 3q -1 4 -3 4t -3 -4l6 0" /><path d="M14 11h-2.5a1.5 1.5 0 0 0 0 3h1a1.5 1.5 0 0 1 0 3h-2.5" /><path d="M12 10v1" /><path d="M12 17v1" /></svg>
              </span>
              <span>Tax-deductible</span>
            </div>
            <div class="donate-trust-item">
              <span class="donate-trust-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M12 3a12 12 0 0 0 8.5 3a12 12 0 0 1 -8.5 15a12 12 0 0 1 -8.5 -15a12 12 0 0 0 8.5 -3" /><path d="M11 11a1 1 0 1 0 2 0a1 1 0 1 0 -2 0" /><path d="M12 12l0 2.5" /></svg>
              </span>
              <span>Secure via Stripe</span>
            </div>
            <div class="donate-trust-item">
              <span class="donate-trust-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M19.5 12.572l-7.5 7.428l-7.5 -7.428a5 5 0 1 1 7.5 -6.566a5 5 0 1 1 7.5 6.572" /><path d="M12 6l-3.293 3.293a1 1 0 0 0 0 1.414l.543 .543c.69 .69 1.81 .69 2.5 0l1 -1a3.182 3.182 0 0 1 4.5 0l2.25 2.25" /><path d="M12.5 15.5l2 2" /><path d="M15 13l2 2" /></svg>
              </span>
              <span>100% to programs</span>
            </div>
          </div>

          <!-- Other ways -->
          <div class="donate-other">
            <div class="donate-other-title">Other ways to give</div>
            <div class="donate-other-grid">
              <div class="donate-other-item">
                <span class="donate-other-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10" /><path d="M3 7l9 6l9 -6" /></svg>
                </span>
                <div>
                  <div class="donate-other-label">By Mail</div>
                  <address class="donate-other-value">
                    9445 Charles Smith Ave<br />
                    Rancho Cucamonga, CA 91730
                  </address>
                </div>
              </div>
              <div class="donate-other-item">
                <span class="donate-other-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" /></svg>
                </span>
                <div>
                  <div class="donate-other-label">By Phone</div>
                  <a href="tel:+19093734760" class="donate-other-link">(909) 373-4760</a>
                </div>
              </div>
              <div class="donate-other-item">
                <span class="donate-other-icon" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M8 12a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" /><path d="M16 12v1.5a2.5 2.5 0 0 0 5 0v-1.5a9 9 0 1 0 -5.5 8.28" /></svg>
                </span>
                <div>
                  <div class="donate-other-label">By Email</div>
                  <a href="mailto:giving@adrianasfoundation.org" class="donate-other-link">giving@adrianasfoundation.org</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>



<style>
  .donate-page {
    position: relative;
    min-height: 100vh;
    background: var(--color-bg-warm);
    padding-top: 4.5rem;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .donate-grain {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 1;
  }

  .donate-mesh {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .donate-inner {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 1.5rem;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 5rem;
    align-items: start;
  }

  /* ── Left ── */
  .donate-left {
    min-width: 0;
  }

  .donate-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-terracotta);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.75rem;
  }

  .donate-eyebrow-line {
    display: block;
    width: 2rem;
    height: 2px;
    background: var(--color-terracotta);
    flex-shrink: 0;
  }

  .donate-heading {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 5vw, 5rem);
    font-weight: 900;
    color: var(--color-bg-dark);
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
  }

  .donate-heading em {
    font-style: italic;
    color: var(--color-terracotta);
  }

  .donate-lead {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: rgba(0, 0, 0, 0.7);
    line-height: 1.75;
    margin: 0 0 1.25rem;
    max-width: 480px;
  }

  /* Ways to Support */
  .donate-ways-support {
    margin: 2.5rem 0;
    padding: 1.75rem;
    background: rgba(255, 255, 255, 0.6);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 0.75rem;
  }

  .donate-ways-support-title {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-terracotta);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
  }

  .donate-ways-support-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.625rem;
  }

  .donate-ways-support-list li {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: rgba(0, 0, 0, 0.75);
    padding-left: 1.25rem;
    position: relative;
    line-height: 1.4;
  }

  .donate-ways-support-list li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--color-gold);
    font-size: 0.75rem;
  }

  /* Partner CTAs */
  .donate-partner-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .donate-partner-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    background: var(--color-gold);
    color: var(--color-bg-dark);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 3rem;
    box-shadow: 0 4px 16px rgba(233, 173, 0, 0.25);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .donate-partner-btn:hover {
    background: #FFD040;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(233, 173, 0, 0.35);
  }

  .donate-partner-btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.75rem;
    background: transparent;
    color: var(--color-bg-dark);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid var(--color-bg-dark);
    border-radius: 3rem;
    transition: background 0.2s, color 0.2s, transform 0.15s;
  }

  .donate-partner-btn-secondary:hover {
    background: var(--color-bg-dark);
    color: var(--color-gold);
    transform: translateY(-2px);
  }


  /* Trust signals */
  .donate-trust {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    padding: 1.5rem 2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .donate-trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(0, 0, 0, 0.65);
    line-height: 1.3;
  }

  .donate-trust-icon {
    color: var(--color-terracotta);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: rgba(233, 173, 0, 0.12);
    border-radius: 50%;
  }

  /* Quote */
  .donate-quote {
    margin: 0;
    padding: 1.5rem;
    border-left: 2px solid var(--color-terracotta);
    background: rgba(6, 87, 154, 0.06);
    border-radius: 0 0.375rem 0.375rem 0;
  }

  .donate-quote p {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: 1.125rem;
    color: rgba(0, 0, 0, 0.8);
    line-height: 1.6;
    margin: 0 0 0.625rem;
  }

  .donate-quote cite {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 0.75rem;
    color: var(--color-terracotta);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ── Right: card ── */
  .donate-card {
    background: var(--color-bg-light-gray);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 1rem;
    overflow: hidden;
  }

  .donate-card-header {
    padding: 2rem 2rem 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .donate-card-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-bg-dark);
    margin: 0 0 0.375rem;
  }

  .donate-card-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(0, 0, 0, 0.45);
    margin: 0;
  }

  /* Amount grid */
  .donate-amounts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    padding: 1.5rem 2rem;
  }

  .donate-amount-btn {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1rem;
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s, transform 0.15s;
    cursor: pointer;
  }

  .donate-amount-btn:hover {
    border-color: var(--color-gold);
    background: rgba(233, 173, 0, 0.12);
    transform: translateY(-2px);
  }

  .donate-amount-value {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1;
  }

  .donate-amount-impact {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: rgba(0, 0, 0, 0.5);
    line-height: 1.4;
  }

  /* Custom amount */
  .donate-custom {
    padding: 0 2rem 1.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    padding-top: 1.5rem;
  }

  .donate-custom-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(0, 0, 0, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .donate-custom-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    background: var(--color-gold);
    border: 1px solid var(--color-gold);
    color: var(--color-bg-dark);
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 0.375rem;
    width: 100%;
    justify-content: center;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .donate-custom-btn:hover {
    background: #FFD040;
    border-color: #FFD040;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(233, 173, 0, 0.3);
  }

  /* Other ways */
  .donate-other {
    padding: 1.5rem 2rem 2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .donate-other-title {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(0, 0, 0, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1rem;
  }

  .donate-other-grid {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .donate-other-item {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .donate-other-icon {
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(6, 87, 154, 0.08);
    border: 1px solid rgba(6, 87, 154, 0.15);
    border-radius: 0.375rem;
    color: var(--color-terracotta);
    font-size: 0.875rem;
    flex-shrink: 0;
  }

  .donate-other-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(0, 0, 0, 0.45);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.2rem;
  }

  .donate-other-value {
    font-style: normal;
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(0, 0, 0, 0.7);
    line-height: 1.5;
  }

  .donate-other-link {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(0, 0, 0, 0.7);
    text-decoration: none;
    transition: color 0.15s;
  }

  .donate-other-link:hover { color: var(--color-terracotta); }

  /* Carousel */
  .donate-carousel {
    margin-bottom: 2.5rem;
    border-radius: 0.625rem;
    overflow: hidden;
    position: relative;
    max-width: 100%;
  }

  /* .donate-carousel::before,
  .donate-carousel::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
