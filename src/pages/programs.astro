---
import BaseLayout from '../layouts/BaseLayout.astro'
import ProgramGrid from '../components/programs/ProgramGrid.astro'
import { getPrograms } from '../content/programs'

const programs = getPrograms()
---

<BaseLayout
  title="Programs — Adriana's Foundation"
  description="Explore all 8 programs from Adriana's Foundation — from Elevate Academy and Soccer Academy to the Annual Santa Tour and Festival de La Familia. Empowering Latino youth and families year-round."
>
  <section class="programs-page" aria-labelledby="programs-heading">
    <div class="programs-page-container">

      <!-- Page header -->
      <div class="programs-page-header">
        <div class="programs-page-label" aria-hidden="true">Programming</div>
        <h1 id="programs-heading" class="programs-page-heading">
          Our Programs
        </h1>
        <p class="programs-page-subheading">
          From mentorship to soccer academies, every program is designed to create access,
          build confidence, and open doors for Latino youth and families.
        </p>
      </div>

      <!-- Program grid -->
      <ProgramGrid programs={programs} />

    </div>
  </section>
</BaseLayout>

<style>
  .programs-page {
    background: #0A1F2D;
    min-height: 100vh;
    padding: 8rem 0 6rem;
  }

  .programs-page-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .programs-page-header {
    margin-bottom: 4rem;
    max-width: 720px;
  }

  .programs-page-label {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: #E9AD00;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }

  .programs-page-heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 900;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
  }

  .programs-page-subheading {
    font-family: var(--font-body);
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin: 0;
  }
</style>
