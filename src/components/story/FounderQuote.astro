---
interface Props {
  quote?: string
  attribution?: string
}

const {
  quote = "From undocumented immigrant to insurance empire. Now building economic mobility for the next generation.",
  attribution = "The Hollywood Reporter"
} = Astro.props
---

<section class="founder-quote" aria-label="Founder's quote">
  <!-- Grain texture overlay -->
  <div
    class="founder-quote-grain"
    style="background-image: url('/textures/grain.svg')"
    aria-hidden="true"
  ></div>

  <!-- Decorative background text -->
  <div class="founder-quote-bg-text" aria-hidden="true">RISE</div>

  <div class="founder-quote-container">
    <blockquote class="founder-quote-block">
      <!-- Decorative opening mark -->
      <span class="founder-quote-mark" aria-hidden="true">"</span>

      <p class="founder-quote-text">{quote}</p>

      <footer class="founder-quote-footer">
        <div class="founder-quote-rule" aria-hidden="true"></div>
        <cite class="founder-quote-attribution">{attribution}</cite>
      </footer>
    </blockquote>
  </div>
</section>

<style>
  .founder-quote {
    min-height: 100vh;
    background: var(--color-bg-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 6rem 1.5rem;
  }

  .founder-quote-grain {
    position: absolute;
    inset: 0;
    opacity: 0.3;
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 1;
  }

  /* Subtle radial glow */
  .founder-quote::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80rem;
    height: 40rem;
    background: radial-gradient(ellipse, rgba(233, 173, 0, 0.15) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  .founder-quote-bg-text {
    position: absolute;
    bottom: -2rem;
    right: -2rem;
    font-family: var(--font-display);
    font-size: clamp(8rem, 20vw, 20rem);
    font-weight: 900;
    color: rgba(233, 173, 0, 0.08);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    z-index: 1;
    letter-spacing: -0.05em;
  }

  .founder-quote-container {
    position: relative;
    z-index: 10;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
  }

  .founder-quote-block {
    margin: 0;
    padding: 0;
  }

  .founder-quote-mark {
    display: block;
    font-family: var(--font-accent);
    font-size: clamp(6rem, 12vw, 10rem);
    color: var(--color-gold);
    line-height: 0.6;
    opacity: 1;
    margin-bottom: -1rem;
    user-select: none;
  }

  .founder-quote-text {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: clamp(1.75rem, 4vw, 3.5rem);
    color: #fff;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 0 0 3rem;
  }

  .founder-quote-footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .founder-quote-rule {
    width: 3rem;
    height: 2px;
    background: var(--color-gold);
    flex-shrink: 0;
  }

  .founder-quote-attribution {
    font-family: var(--font-body);
    font-style: normal;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }
</style>
