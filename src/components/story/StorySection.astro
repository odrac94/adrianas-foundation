---
import { Image } from 'astro:assets'
import storyImage from '../../assets/story-section.jpg'

const transformations = [
  { from: 'Uncertainty', to: 'Confidence' },
  { from: 'Low-wage work', to: 'Career pathways' },
  { from: 'Limited access', to: 'Real opportunity' }
]
---

<section class="story" aria-labelledby="story-heading">
  <div class="story-container">

    <div class="story-layout">
      <!-- Left: label + heading + photo -->
      <div class="story-left" data-animate="fade-right">
        <div class="story-label" aria-hidden="true">Our Story</div>
        <h1 id="story-heading" class="story-heading">
          We grow together,<br />
          so our community<br />
          can <em>rise together</em>
        </h1>

        <!-- Participants photo -->
        <div class="story-photo" data-animate="fade-up">
          <Image
            src={storyImage}
            alt="Program participants at Adriana's Foundation"
            class="story-photo-img"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Right: content -->
      <div class="story-right" data-animate="fade-left" data-delay="0.15">
        <p class="story-text">
          Adriana's Foundation empowers Latino youth and women with the skills, mentorship,
          and opportunities needed to build meaningful careers and achieve economic mobility.
        </p>
        <p class="story-text">
          Through mentorship, life-skills training, certifications, and job placement,
          we prepare participants to succeed in today's workforce.
        </p>

        <!-- Transformation cards -->
        <div class="story-transformations" aria-label="How we help participants transform">
          <div class="story-transformations-label">Our programs help participants move</div>
          <div class="story-transformation-cards" data-animate="stagger">

            <div class="story-transformation-card">
              <span class="story-transformation-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M11.884 2.007l.114 -.007l.118 .007l.059 .008l.061 .013l.111 .034a.993 .993 0 0 1 .217 .112l.104 .082l.255 .218a11 11 0 0 0 7.189 2.537l.342 -.01a1 1 0 0 1 1.005 .717a13 13 0 0 1 -9.208 16.25a1 1 0 0 1 -.502 0a13 13 0 0 1 -9.209 -16.25a1 1 0 0 1 1.005 -.717a11 11 0 0 0 7.531 -2.527l.263 -.225l.096 -.075a.993 .993 0 0 1 .217 -.112l.112 -.034a.97 .97 0 0 1 .119 -.021z" /></svg>
              </span>
              <div class="story-transformation-content">
                <span class="story-transformation-from">{transformations[0].from}</span>
                <div class="story-transformation-arrow-wrap">
                  <span class="story-transformation-line" aria-hidden="true"></span>
                  <svg class="story-transformation-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="story-transformation-to">{transformations[0].to}</span>
              </div>
            </div>

            <div class="story-transformation-card">
              <span class="story-transformation-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M3 19a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" /><path d="M19 7a2 2 0 1 0 0 -4a2 2 0 0 0 0 4" /><path d="M11 19h5.5a3.5 3.5 0 0 0 0 -7h-8a3.5 3.5 0 0 1 0 -7h4.5" /></svg>
              </span>
              <div class="story-transformation-content">
                <span class="story-transformation-from">{transformations[1].from}</span>
                <div class="story-transformation-arrow-wrap">
                  <span class="story-transformation-line" aria-hidden="true"></span>
                  <svg class="story-transformation-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="story-transformation-to">{transformations[1].to}</span>
              </div>
            </div>

            <div class="story-transformation-card">
              <span class="story-transformation-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M3 13a2 2 0 0 1 2 -2h10a2 2 0 0 1 2 2v6a2 2 0 0 1 -2 2h-10a2 2 0 0 1 -2 -2l0 -6" /><path d="M9 16a1 1 0 1 0 2 0a1 1 0 0 0 -2 0" /><path d="M13 11v-4a4 4 0 1 1 8 0v4" /></svg>
              </span>
              <div class="story-transformation-content">
                <span class="story-transformation-from">{transformations[2].from}</span>
                <div class="story-transformation-arrow-wrap">
                  <span class="story-transformation-line" aria-hidden="true"></span>
                  <svg class="story-transformation-arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                    <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
                <span class="story-transformation-to">{transformations[2].to}</span>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .story {
    background: rgba(233, 173, 0, 0.15);
    padding: 8rem 0 6rem;
  }

  .story-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .story-layout {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 6rem;
    align-items: start;
  }

  .story-label {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
  }

  .story-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 700;
    color: var(--color-text-dark);
    line-height: 1.15;
    margin: 0;
  }

  .story-heading em {
    font-style: italic;
    color: var(--color-terracotta);
  }

  .story-text {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    color: rgba(0, 0, 0, 0.75);
    line-height: 1.75;
    margin: 0 0 1.25rem;
  }

  .story-transformations {
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .story-transformations-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-terracotta);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 1.5rem;
  }

  .story-transformation-cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .story-transformation-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-text-muted);
    border: 1px solid rgba(0, 0, 0, 0.06);
    border-radius: 0.75rem;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    backdrop-filter: blur(4px);
  }

  .story-transformation-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    border-color: rgba(233, 173, 0, 0.3);
  }

  .story-transformation-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(6, 87, 154, 0.1);
    border-radius: 0.5rem;
    color: var(--color-terracotta);
  }

  .story-transformation-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 0;
  }

  .story-transformation-from {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: rgba(0, 0, 0, 0.5);
    white-space: nowrap;
    text-decoration: line-through;
    text-decoration-color: rgba(0, 0, 0, 0.2);
  }

  .story-transformation-arrow-wrap {
    display: flex;
    align-items: center;
    gap: 0;
    flex-shrink: 0;
  }

  .story-transformation-line {
    width: 1.5rem;
    height: 2px;
    background: linear-gradient(90deg, rgba(233, 173, 0, 0.3), var(--color-gold));
    display: block;
  }

  .story-transformation-arrow {
    color: var(--color-gold);
    flex-shrink: 0;
    margin-left: -6px;
  }

  .story-transformation-to {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-terracotta);
    white-space: nowrap;
  }

  .story-photo {
    margin-top: 2.5rem;
    border-radius: 0.625rem;
    overflow: hidden;
  }

  .story-photo-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 12 / 7;
    object-fit: cover;
  }

  @media (max-width: 1024px) {
    .story-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
