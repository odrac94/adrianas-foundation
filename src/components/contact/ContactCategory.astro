---
import type { ContactEntry } from '../../types/index'

interface Props {
  entry: ContactEntry
  iconHtml?: string
}

const { entry, iconHtml = '' } = Astro.props
---

<div class="contact-category" data-animate="fade-up">
  <div class="contact-category-icon" aria-hidden="true" set:html={iconHtml} />
  <div class="contact-category-content">
    <h2 class="contact-category-title">{entry.category}</h2>
    <p class="contact-category-description">{entry.description}</p>
    <a
      href={`mailto:${entry.email}`}
      class="contact-category-email"
      aria-label={`Email ${entry.category}: ${entry.email}`}
    >
      {entry.email}
    </a>
  </div>
</div>

<style>
  .contact-category {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 2rem;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 0.75rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .contact-category:hover {
    border-color: rgba(233, 173, 0, 0.25);
    background: rgba(233, 173, 0, 0.08);
  }

  .contact-category-icon {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(6, 87, 154, 0.1);
    border: 1px solid rgba(6, 87, 154, 0.2);
    border-radius: 0.5rem;
    color: #06579A;
    font-size: 1.125rem;
    flex-shrink: 0;
  }

  .contact-category-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    color: #0A1F2D;
    margin: 0 0 0.5rem;
  }

  .contact-category-description {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: rgba(0, 0, 0, 0.55);
    line-height: 1.6;
    margin: 0 0 0.875rem;
  }

  .contact-category-email {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: #06579A;
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
    padding-bottom: 1px;
  }

  .contact-category-email:hover {
    border-bottom-color: #06579A;
  }
</style>
