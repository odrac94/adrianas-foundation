---
import { Image } from 'astro:assets'
import communityPhoto from '../../assets/adriana-gallardo-community.jpg'

const values = [
  { label: 'Growth', icon: '↑' },
  { label: 'Opportunity', icon: '◇' },
  { label: 'Knowledge', icon: '◎' },
  { label: 'Integrity', icon: '✦' }
]

const mission = "Adriana's Foundation develops confident, career-ready leaders by providing free, career-focused education, mentorship, and real-world experience, guiding Latinos, women, and young adults from training to employment and long-term economic stability."

const vision = "We envision a future where underserved communities—especially Latinos, women, and young adults—have equitable access to high-quality career education, meaningful employment, and the tools to thrive in an evolving workforce, unlocking economic mobility and driving generational change."
---

<section class="mission" aria-labelledby="mission-heading">
  <div class="mission-container">

    <!-- Section label -->
    <div class="mission-label" aria-hidden="true" data-animate="fade-up">Who We Are</div>

    <div class="mission-grid">
      <!-- Mission -->
      <div class="mission-block" data-animate="fade-right">
        <h2 id="mission-heading" class="mission-block-title">Mission</h2>
        <p class="mission-block-text">{mission}</p>
      </div>

      <!-- Divider -->
      <div class="mission-divider" aria-hidden="true"></div>

      <!-- Vision -->
      <div class="mission-block" data-animate="fade-left">
        <h2 class="mission-block-title">Vision</h2>
        <p class="mission-block-text">{vision}</p>
      </div>
    </div>

    <!-- Community photo -->
    <!-- <div class="mission-photo" data-animate="fade-up">
      <Image
        src={communityPhoto}
        alt="Adriana's Foundation community members together"
        class="mission-photo-img"
        loading="lazy"
      />
    </div> -->

    <!-- Values -->
    <div class="mission-values" aria-label="Core values" data-animate="fade-up" data-delay="0.2">
      <span class="mission-values-label">Core Values</span>
      <ul class="mission-values-list" role="list" data-animate="stagger">
        {values.map((v) => (
          <li class="mission-value-tag">
            <span class="mission-value-icon" aria-hidden="true">{v.icon}</span>
            {v.label}
          </li>
        ))}
      </ul>
    </div>

  </div>
</section>

<style>
  .mission {
    background: rgba(233, 173, 0, 0.15);
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
  }

  /* Subtle decorative element */
  .mission::before {
    display: none;
  }

  .mission-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .mission-label {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-terracotta);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 3rem;
  }

  .mission-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 3rem;
    align-items: start;
    margin-bottom: 4rem;
  }

  .mission-block-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 1rem;
  }

  .mission-block-text {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    color: var(--color-text-dark);
    line-height: 1.7;
    margin: 0;
  }

  .mission-divider {
    width: 1px;
    background: rgba(6, 87, 154, 0.2);
    align-self: stretch;
    min-height: 8rem;
  }

  /* Values */
  .mission-values {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-top: 3rem;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
  }

  .mission-values-label {
    font-family: var(--font-body);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-bg-dark);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    flex-shrink: 0;
  }

  .mission-values-list {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mission-value-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: transparent;
    border: 1px solid rgba(233, 173, 0, 0.4);
    border-radius: 2rem;
    font-family: var(--font-body);
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--color-text-dark);
    transition: border-color 0.2s, background 0.2s;
  }

  .mission-value-tag:hover {
    border-color: var(--color-gold);
    background: rgba(233, 173, 0, 0.15);
  }

  .mission-value-icon {
    color: var(--color-gold);
    font-size: 0.75rem;
  }

  .mission-photo {
    margin-bottom: 3rem;
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .mission-photo-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 1;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .mission-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .mission-divider {
      width: 3rem;
      height: 1px;
      min-height: unset;
      align-self: auto;
    }
  }
</style>
