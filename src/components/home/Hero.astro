---
import { Image } from 'astro:assets'
import img1 from '../../assets/hero/vertical-1.jpg'
import img2 from '../../assets/hero/vertical-2.jpg'
import img3 from '../../assets/hero/vertical-3.jpg'
import img4 from '../../assets/hero/square-1.jpg'
import img5 from '../../assets/hero/square-2.jpg'
import img6 from '../../assets/hero/square-3.jpg'
import img7 from '../../assets/hero/horizontal-1.jpg'
import img8 from '../../assets/hero/horizontal-2.jpg'
import img9 from '../../assets/hero/horizontal-3.jpg'

interface Props {
  headline?: string
  subheadline?: string
  ctaLabel?: string
  ctaHref?: string
}

const {
  headline = 'Free Training. Real Skills. Real Jobs. Real Futures.',
  subheadline = 'Adriana\'s Foundation provides free, career-focused education for Latinos, women, and young adults—guiding students from training to employment through mentorship, internships, and job placement.',
  ctaLabel = 'Apply for the Program',
  ctaHref = '/academy',
} = Astro.props

// 2 images per cell, no repeats across cells
// tall cell = vertical/portrait images
// normal/wide cells = horizontal/square images
const cells = [
  {
    images: [{ src: img1, alt: "Workshop" }, { src: img3, alt: 'Youth mentorship program' }, { src: img2, alt: 'Youth mentorship program' }],
    span: 'tall',
    fit: 'object-center'   // center all images
  },
  {
    images: [{ src: img6, alt: 'Workshops' }, { src: img4, alt: 'Festival de La Familia' }, { src: img5, alt: 'Festival de La Familia' }],
    span: 'normal',
    fit: 'object-center'   // horizontal/square → center
  },
  {
    images: [{ src: img8, alt: 'Back-to-School Drive' }, { src: img7, alt: 'Soccer Academy' }, { src: img9, alt: 'Soccer Academy' }],
    span: 'normal',
    fit: 'object-center'
  },
  {
    images: [{ src: img7, alt: 'Food Drive' }, { src: img8, alt: 'Community event' }],
    span: 'wide',
    fit: 'object-center'
  },
]
---

<section class="hero" aria-label="Hero">
  <!-- Mesh gradient background -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-bg-mesh"></div>
    <div class="hero-grain" style="background-image: url('/textures/grain.svg')"></div>
  </div>

  <div class="hero-inner">

    <!-- ── Left: text ── -->
    <div class="hero-text">
      <div class="hero-eyebrow" aria-hidden="true">
        <span class="hero-eyebrow-line"></span>
        <span class="hero-eyebrow-label">Adriana's Foundation</span>
      </div>

      <h1 class="hero-headline">
        {headline.split(' ').map((word, i) => (
          <span class="hero-word" style={`animation-delay: ${0.1 + i * 0.1}s`}>{word}</span>
        ))}
      </h1>

      <p class="hero-subheadline">{subheadline}</p>

      <div class="hero-actions">
        <a href={ctaHref} class="hero-cta-primary">
          {ctaLabel}
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a
          href="/donate"
          class="hero-cta-secondary"
        >
          Support Our Mission
        </a>
      </div>


    </div>

    <!-- ── Right: collage ── -->
    <div class="hero-collage" aria-label="Foundation photo collage" role="img">
      {cells.map((cell, cellIdx) => (
        <div class={`collage-cell collage-cell--${cell.span}`}>
          {cell.images.map((img, imgIdx) => {
            const totalImages = cell.images.length
            const cycleDur = totalImages * 6
            const delay = imgIdx * 6 + cellIdx * 1.5
            const isBase = imgIdx === 0
            return (
              <Image
                src={img.src}
                alt={img.alt}
                class={`collage-img ${cell.fit} ${isBase ? 'collage-img--base' : ''}`}
                style={isBase ? '' : `--delay: ${delay}s; --cycle: ${cycleDur}s; --count: ${totalImages}`}
                width={800}
                height={1000}
                loading={cellIdx === 0 && imgIdx === 0 ? 'eager' : 'lazy'}
                format="webp"
                quality={90}
              />
            )
          })}
          <div class="collage-cell-overlay" aria-hidden="true"></div>
        </div>
      ))}

      <!-- Floating decorative elements -->
      <div class="collage-deco collage-deco--ring" aria-hidden="true"></div>
      <div class="collage-deco collage-deco--dot" aria-hidden="true"></div>
    </div>

  </div>

  <!-- Bottom fade -->
  <div class="hero-bottom-fade" aria-hidden="true"></div>
</section>

<style>
  /* ── Section ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 4.5rem;
    overflow: hidden;
    background: var(--color-bg-dark);
  }

  /* ── Background mesh ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 70% 40%, rgba(154, 117, 6, 0.22) 0%, transparent 60%),
      radial-gradient(ellipse 60% 80% at 85% 80%, rgba(233, 173, 0, 0.15) 0%, transparent 55%),
      radial-gradient(ellipse 50% 50% at 10% 20%, rgba(233, 173, 0, 0.08) 0%, transparent 50%),
      var(--color-bg-light-gray);
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    opacity: 0.3;
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
    mix-blend-mode: overlay;
  }

  /* ── Layout ── */
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 3rem;
    align-items: center;
  }

  /* ── Left: text ── */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.75rem;
  }

  .hero-eyebrow-line {
    display: block;
    width: 2.5rem;
    height: 2px;
    background: var(--color-gold);
  }

  .hero-eyebrow-label {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 5.5vw, 5.5rem);
    font-weight: 900;
    line-height: 0.93;
    letter-spacing: -0.03em;
    color: var(--color-bg-dark);
    margin: 0 0 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.2em;
  }

  .hero-word {
    display: inline-block;
    opacity: 0;
    transform: translateY(24px) skewY(2deg);
    animation: wordReveal 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes wordReveal {
    to { opacity: 1; transform: translateY(0) skewY(0deg); }
  }

  .hero-word:last-child { color: var(--color-gold); }

  .hero-subheadline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.5vw, 1.25rem);
    color: var(--color-bg-dark);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 440px;
  }

  .hero-actions {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    background: var(--color-gold);
    color: var(--color-bg-dark);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 3rem;
    letter-spacing: 0.02em;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 16px rgba(233, 173, 0, 0.25);
  }

  .hero-cta-primary:hover {
    background: #FFD040;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(233, 173, 0, 0.35);
  }

  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 1rem 2rem;
    background: transparent;
    color: var(--color-bg-dark);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    border: 2px solid var(--color-bg-dark);
    border-radius: 3rem;
    transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.15s;
  }

  .hero-cta-secondary:hover {
    background: var(--color-bg-dark);
    color: var(--color-gold);
    border-color: var(--color-bg-dark);
    transform: translateY(-2px);
  }



  /* ── Right: collage ── */
  .hero-collage {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1.4fr 1fr;
    gap: 0.625rem;
    height: 560px;
  }

  /* Cell spans */
  .collage-cell--tall {
    grid-row: span 2;
  }

  .collage-cell--wide {
    /* normal, fills its cell */
  }

  .collage-cell {
    position: relative;
    border-radius: 0.625rem;
    overflow: hidden;
    background: var(--color-terracotta);
  }

  /* Each image in a cell stacks and fades */
  .collage-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0;
    will-change: opacity;
  }

  /* Base image: always visible as fallback */
  .collage-img.collage-img--base {
    opacity: 1;
    z-index: 0;
  }

  /* Animated images: crossfade on top of base */
  .collage-img:not(.collage-img--base) {
    z-index: 1;
    animation: collageCrossfade var(--cycle) ease-in-out infinite var(--delay);
  }

  /* Object position helpers */
  .collage-img.object-top    { object-position: top center; }
  .collage-img.object-center { object-position: center; }
  .collage-img.object-bottom { object-position: bottom center; }

  @keyframes collageCrossfade {
    0%    { opacity: 0; }
    5%    { opacity: 1; }
    33%   { opacity: 1; }
    38%   { opacity: 0; }
    100%  { opacity: 0; }
  }

  /* Per-cell gradient overlay — creates depth + brand feel */
  .collage-cell-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      135deg,
      rgba(10, 31, 45, 0.25) 0%,
      transparent 50%,
      rgba(233, 173, 0, 0.08) 100%
    );
  }

  /* Tall cell gets stronger bottom fade */
  .collage-cell--tall .collage-cell-overlay {
    background: linear-gradient(
      to bottom,
      transparent 50%,
      rgba(10, 31, 45, 0.5) 100%
    );
  }

  /* Decorative floating elements */
  .collage-deco {
    position: absolute;
    pointer-events: none;
    z-index: 10;
  }

  .collage-deco--ring {
    width: 5rem;
    height: 5rem;
    border: 1.5px solid rgba(233, 173, 0, 0.4);
    border-radius: 50%;
    top: -1.5rem;
    right: -1.5rem;
    animation: rotateSlow 20s linear infinite;
  }

  .collage-deco--dot {
    width: 0.5rem;
    height: 0.5rem;
    background: var(--color-gold);
    border-radius: 50%;
    bottom: 1.5rem;
    left: -0.75rem;
    box-shadow: 0 0 12px rgba(233, 173, 0, 0.6);
    animation: pulseDot 3s ease-in-out infinite;
  }

  @keyframes rotateSlow {
    to { transform: rotate(360deg); }
  }

  @keyframes pulseDot {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.5); opacity: 1; }
  }

  /* ── Bottom fade into next section ── */
  .hero-bottom-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 8rem;
    background: linear-gradient(to bottom, transparent, var(--color-bg-light-gray));
    z-index: 3;
    pointer-events: none;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-collage {
      height: 380px;
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .hero-collage {
      height: 280px;
      gap: 0.375rem;
    }
  }
</style>
