---
import { Image } from 'astro:assets'
import heroImg from '../../assets/hero/adrianas-foundation-hero.webp'

interface Props {
  eyebrow?: string
  headlineLines?: string[]
  accentWord?: string
  subheadline?: string
  primaryLabel?: string
  primaryHref?: string
  secondaryLabel?: string
  secondaryHref?: string
}

const {
  eyebrow = "Adriana's Foundation",
  headlineLines = ['Free Training.', 'Real Skills.', 'Real Jobs.', 'Real '],
  accentWord = 'Futures.',
  subheadline = "Adriana's Foundation provides free, career-focused education for Latinos, women, and young adults—guiding students from training to employment through mentorship, internships, and job placement.",
  primaryLabel = 'Apply for the Program',
  primaryHref = '/academy',
  secondaryLabel = 'Support Our Mission',
  secondaryHref = '/donate',
} = Astro.props
---

<section class="hero" aria-label="Hero">
  <!-- ── Background image ── -->
  <div class="hero-bg" aria-hidden="true">
    <Image
      src={heroImg}
      alt=""
      class="hero-bg-img"
      widths={[1280, 1600, 2000, 2560]}
      sizes="100vw"
      loading="eager"
      format="webp"
      quality={85}
    />
    <!-- Dark wash from left for text legibility -->
    <div class="hero-wash" aria-hidden="true"></div>
    <!-- Top gradient to blend with fixed navigation -->
    <div class="hero-top-fade" aria-hidden="true"></div>
    <!-- Grain overlay -->
    <div class="hero-grain" style="background-image: url('/textures/grain.svg')" aria-hidden="true"></div>
  </div>

  <!-- ── Content ── -->
  <div class="hero-inner">
    <div class="hero-content">

      <!-- Eyebrow -->
      <div class="hero-eyebrow" aria-hidden="true">
        <span class="hero-eyebrow-line"></span>
        <span class="hero-eyebrow-label">{eyebrow}</span>
      </div>

      <!-- Headline -->
      <h1 class="hero-headline">
        {headlineLines.map((line, i) => (
          <span class="hero-line" style={`animation-delay: ${0.15 + i * 0.12}s`}>
            {line}
            {i === headlineLines.length - 1 && (
              <em class="hero-accent">{accentWord}</em>
            )}
          </span>
        ))}
      </h1>

      <!-- Subheadline -->
      <p class="hero-subheadline">{subheadline}</p>

      <!-- Actions -->
      <div class="hero-actions">
        <a href={primaryHref} class="hero-cta-primary">
          <span>{primaryLabel}</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href={secondaryHref} class="hero-cta-secondary">
          {secondaryLabel}
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 4.5rem;
    overflow: hidden;
    background: var(--color-bg-dark);
    isolation: isolate;
  }

  /* ── Background ── */
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: saturate(0.9) contrast(1.02);
  }

  /* Strong wash from left → transparent right, plus subtle darken overall */
  .hero-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        100deg,
        var(--color-bg-dark) 0%,
        rgba(10, 31, 45, 0.92) 28%,
        rgba(10, 31, 45, 0.72) 48%,
        rgba(10, 31, 45, 0.45) 68%,
        rgba(10, 31, 45, 0.28) 100%
      ),
      linear-gradient(
        180deg,
        rgba(10, 31, 45, 0.25) 0%,
        rgba(10, 31, 45, 0.15) 55%,
        rgba(10, 31, 45, 0.35) 100%
      );
    pointer-events: none;
  }

  .hero-top-fade {
    position: absolute;
    inset: 0 0 auto 0;
    height: 8rem;
    background: linear-gradient(
      to bottom,
      rgba(10, 31, 45, 0.85) 0%,
      transparent 100%
    );
    pointer-events: none;
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    opacity: 0.18;
    background-repeat: repeat;
    background-size: 200px 200px;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  /* ── Layout ── */
  .hero-inner {
    position: relative;
    z-index: 2;
    max-width: 1280px;
    margin: 0 auto;
    padding: 5rem 1.5rem 7rem;
    width: 100%;
  }

  .hero-content {
    max-width: 620px;
  }

  /* ── Eyebrow ── */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: heroFadeIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  .hero-eyebrow-line {
    display: block;
    width: 2.5rem;
    height: 2px;
    background: var(--color-gold);
  }

  .hero-eyebrow-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }

  /* ── Headline ── */
  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.75rem, 6vw, 5rem);
    font-weight: 900;
    line-height: 0.98;
    letter-spacing: -0.025em;
    color: #ffffff;
    margin: 0 0 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }

  .hero-line {
    display: block;
    opacity: 0;
    transform: translateY(28px);
    animation: heroLineReveal 0.85s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-accent {
    font-style: italic;
    color: var(--color-gold);
    margin-left: 0.1em;
  }

  @keyframes heroLineReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes heroFadeIn {
    to { opacity: 1; }
  }

  /* ── Subheadline ── */
  .hero-subheadline {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.25vw, 1.125rem);
    font-weight: 400;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 520px;
    opacity: 0;
    animation: heroFadeIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;
  }

  /* ── Actions ── */
  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
    opacity: 0;
    animation: heroFadeIn 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
  }

  .hero-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 1.75rem;
    background: var(--color-gold);
    color: var(--color-bg-dark);
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    border-radius: 3rem;
    box-shadow: 0 4px 16px rgba(233, 173, 0, 0.25);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .hero-cta-primary:hover {
    background: #FFD040;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(233, 173, 0, 0.45);
  }

  .hero-cta-primary svg {
    transition: transform 0.2s;
  }

  .hero-cta-primary:hover svg {
    transform: translateX(3px);
  }

  .hero-cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 1rem 1.75rem;
    background: transparent;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    border: 1.5px solid rgba(255, 255, 255, 0.7);
    border-radius: 3rem;
    transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.15s;
  }

  .hero-cta-secondary:hover {
    background: #ffffff;
    color: var(--color-bg-dark);
    border-color: #ffffff;
    transform: translateY(-2px);
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow,
    .hero-line,
    .hero-subheadline,
    .hero-actions {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero-bg-img {
      object-position: 70% center;
    }

    .hero-wash {
      background:
        linear-gradient(
          100deg,
          var(--color-bg-dark) 0%,
          rgba(10, 31, 45, 0.94) 40%,
          rgba(10, 31, 45, 0.78) 60%,
          rgba(10, 31, 45, 0.5) 100%
        );
    }
  }

  @media (max-width: 768px) {
    .hero-inner {
      padding: 4rem 1.25rem 6rem;
    }

    .hero-content {
      max-width: 100%;
    }

    .hero-bg-img {
      object-position: 75% center;
    }

    .hero-wash {
      background: linear-gradient(
        180deg,
        rgba(10, 31, 45, 0.92) 0%,
        rgba(10, 31, 45, 0.78) 50%,
        rgba(10, 31, 45, 0.6) 100%
      );
    }

    .hero-headline {
      font-size: clamp(2.25rem, 9vw, 3.5rem);
    }

    .hero-actions {
      gap: 0.75rem;
    }

    .hero-cta-primary,
    .hero-cta-secondary {
      padding: 0.875rem 1.5rem;
      font-size: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-cta-primary,
    .hero-cta-secondary {
      justify-content: center;
    }
  }
</style>
