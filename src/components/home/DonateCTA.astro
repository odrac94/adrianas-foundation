---
import { Image } from 'astro:assets'
import donateImage from '../../assets/donate-cta.png'

interface Props {
  stripeUrl?: string
}

const { stripeUrl = '/donate' } = Astro.props
---

<section class="donate" aria-labelledby="donate-heading">
  <div class="donate-grain" style="background-image: url('/textures/grain.svg')" aria-hidden="true"></div>

  <div class="donate-container">

    <div class="donate-content" data-animate="fade-right">
      <div class="donate-label" aria-hidden="true">Support Our Mission</div>
      <h2 id="donate-heading" class="donate-heading">
        Make an impact<br />
        <span class="donate-heading-accent">today</span>
      </h2>
      <p class="donate-text">
        Every contribution goes directly to programs that transform lives.
        100% of proceeds are reinvested into our community — never toward administrative profit.
      </p>

      <!-- Primary CTA -->
      <a
        href={stripeUrl}
        class="donate-btn-primary"
      >
        Give Today
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3.75 9h10.5M9.75 4.5L14.25 9l-4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

    <!-- Other ways to give -->
    <div class="donate-ways" aria-label="Other ways to donate" data-animate="fade-left" data-delay="0.15">
      <h3 class="donate-ways-title">Other Ways to Give</h3>

      <div class="donate-way">
        <div class="donate-way-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10" /><path d="M3 7l9 6l9 -6" /></svg>
        </div>
        <div>
          <div class="donate-way-label">Donate by Mail</div>
          <address class="donate-way-address">
            Adriana's Foundation<br />
            9445 Charles Smith Ave<br />
            Rancho Cucamonga, CA 91730
          </address>
        </div>
      </div>

      <div class="donate-way">
        <div class="donate-way-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-phone"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2" /></svg>
        </div>
        <div>
          <div class="donate-way-label">Donate by Phone</div>
          <a href="tel:+19093734760" class="donate-way-link">(909) 373-4760</a>
        </div>
      </div>

      <div class="donate-way">
        <div class="donate-way-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M8 12a4 4 0 1 0 8 0a4 4 0 1 0 -8 0" /><path d="M16 12v1.5a2.5 2.5 0 0 0 5 0v-1.5a9 9 0 1 0 -5.5 8.28" /></svg>
        </div>
        <div>
          <div class="donate-way-label">Email Our Giving Team</div>
          <a href="mailto:giving@adrianasfoundation.org" class="donate-way-link">
            giving@adrianasfoundation.org
          </a>
        </div>
      </div>

      <!-- Impact photo -->
      <div class="donate-ways-photo">
        <Image
          src={donateImage}
          alt="Families served by Adriana's Foundation"
          class="donate-ways-photo-img"
          loading="lazy"
        />
      </div>
    </div>

  </div>
</section>

<style>
  .donate {
    background: #0A1F2D;
    padding: 6rem 0;
    position: relative;
    overflow: hidden;
    border-top: 1px solid rgba(233, 173, 0, 0.18);
  }

  /* Gold glow */
  .donate::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, #E9AD00, transparent);
  }

  .donate-grain {
    position: absolute;
    inset: 0;
    opacity: 0.2;
    background-repeat: repeat;
    background-size: 200px 200px;
    pointer-events: none;
  }

  .donate-container {
    position: relative;
    z-index: 1;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .donate-label {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: #E9AD00;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1.5rem;
  }

  .donate-heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 900;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.03em;
    margin: 0 0 1.5rem;
  }

  .donate-heading-accent {
    color: #E9AD00;
    font-style: italic;
  }

  .donate-text {
    font-family: var(--font-body);
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.7;
    margin: 0 0 2.5rem;
    max-width: 480px;
  }

  .donate-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 1rem 2.5rem;
    background: #E9AD00;
    color: #0A1F2D;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: 0.375rem;
    letter-spacing: 0.02em;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .donate-btn-primary:hover {
    background: #FFD040;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(233, 173, 0, 0.3);
  }

  /* Ways to give */
  .donate-ways {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .donate-ways-title {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 0.5rem;
  }

  .donate-way {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .donate-way-icon {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(233, 173, 0, 0.18);
    border: 1px solid rgba(233, 173, 0, 0.3);
    border-radius: 0.375rem;
    color: #E9AD00;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .donate-way-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.25rem;
  }

  .donate-way-address {
    font-style: normal;
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
  }

  .donate-way-link {
    font-family: var(--font-body);
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.15s;
  }

  .donate-way-link:hover { color: #E9AD00; }

  .donate-ways-photo {
    border-radius: 0.625rem;
    overflow: hidden;
    margin-top: 0.5rem;
  }

  .donate-ways-photo-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    opacity: 0.85;
  }

  @media (max-width: 1024px) {
    .donate-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
